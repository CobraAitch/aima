# LLM provider: ollama | openai | anthropic | github
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# required for provider=openai
# OPENAI_API_KEY=...

# required for provider=anthropic
# ANTHROPIC_API_KEY=...

# required for provider=github
# GITHUB_TOKEN=...

# Per-agent temperatures (0.0 = deterministic, 1.0 = creative)
# TEMPERATURE_RESEARCH=0.3
# TEMPERATURE_STRATEGY=0.5
# TEMPERATURE_PLANNER=0.7
# TEMPERATURE_CONTENT=0.8

# Max chars of prior context passed to content agent
# CONTENT_CONTEXT_LIMIT=800

DEBUG=false
